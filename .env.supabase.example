# This app uses Prisma + NextAuth (not @supabase/supabase-js). Only DATABASE_URL is required.

# Pooled connection — use for the running app (Vercel / npm run dev)
DATABASE_URL="postgresql://postgres.fynwqohlhfdidfrwxqmi:YOUR_DB_PASSWORD@aws-1-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — use for prisma db push / migrations
# Session pooler (IPv4-friendly). Use db.*.supabase.co:5432 only if your network supports IPv6.
DIRECT_URL="postgresql://postgres.fynwqohlhfdidfrwxqmi:YOUR_DB_PASSWORD@aws-1-eu-west-2.pooler.supabase.com:5432/postgres"

AUTH_SECRET="generate-a-random-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"
