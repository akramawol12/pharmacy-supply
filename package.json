{
  "name": "pharmacy-supply",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/sync-db-provider.mjs && next dev -p 3000",
    "build": "node scripts/sync-db-provider.mjs && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "node scripts/sync-db-provider.mjs && prisma db push",
    "db:supabase": "dotenv -e .env.local -- node scripts/sync-db-provider.mjs && dotenv -e .env.local -- prisma db push --accept-data-loss && dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:check": "dotenv -e .env.local -- node scripts/check-db.mjs",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "dev:supabase": "dotenv -e .env.local -- next dev"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "next-auth": "^5.0.0-beta.28",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "prisma": "^6.8.2",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
